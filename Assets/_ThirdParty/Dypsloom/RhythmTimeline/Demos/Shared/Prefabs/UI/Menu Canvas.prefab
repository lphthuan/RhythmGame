      m_Calls: []
  m_text: "Rhythm Timeline is a system built on top of the Unity Timeline and allows
    you to create rhythm tracks very easily in the Unity Editor. \n\nIn addition
    all Unity Timeline features work too, so you may create cinematic views animated
    by the timeline while your rhythm tracks are playing. Everything can be previewed
    in the Editor, no need to press play to see the result!\n\nThe Demo includes
    11 tracks (3 of them are metronomes testing tracks). Most of the songs included
    are original to this project and were made by talented musicians. Make sure to
    check them out online if you enjoy their songs.\n\nTo learn more about Rhythm
    Timeline please find the documentation on our website: \nhttps://dypsloom.com/Assets/RhythmTimeline\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9f2c60921ae5de342ace3043644906b3, type: 2}
