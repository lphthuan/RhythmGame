  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'This demo showcases a simple multiplayer setup.


    You will find that
    There are two RhythmDirector, each with a unique "PlayerID"

    This "PlayerID"
    is used on the ScoreManager, Event Listeners, etc... to get the reference to
    the specified RhythmDirector.


    This allows two RhytmDirectors to play at
    the same time each with their own score.



    IMPORTANT RESTRICTION: The same
    RhytmTimeline CANNOT be used in both directors at the same time! Duplicate the
    RhytmTimeline before playing it on the other players. This cannot be done at
    runtime. More details on this in the documentation '
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
